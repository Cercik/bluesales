{
  "name": "bluesales-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "BlueSales internal sales and communications platform with Node.js, Express, and Firestore",
  "scripts": {
    "start": "node src/main.js",
    "dev": "node --watch src/main.js",
    "check": "node --check src/main.js && node --check src/api/routes/api-router.js && node --check src/modules/identity/dni-validation.service.js && node --check public/js/main.js",
    "preflight:prod": "node scripts/preflight-production.mjs",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "clean:proxy": "node scripts/clean-proxy.cjs",
    "migrate:force": "node scripts/force-migrate-state.mjs",
    "audit:passwords": "node scripts/audit-password-hashes.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "firebase": "^12.12.0",
    "helmet": "^8.1.0",
    "zod": "^4.3.6"
  }
}
